{
  "name": "oh-my-knowledge",
  "version": "0.8.1",
  "description": "Knowledge artifact evaluation toolkit — benchmark your skills with objective data",
  "type": "module",
  "bin": {
    "omk": "cli.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "cli.mjs",
    "lib/",
    "examples/"
  ],
  "scripts": {
    "lint": "eslint 'lib/**/*.mjs' 'cli.mjs' 'test/**/*.mjs'",
    "test": "node --test 'test/*.mjs'",
    "ci": "yarn lint && yarn test"
  },
  "keywords": [
    "knowledge-engineering",
    "skill-evaluation",
    "benchmark",
    "llm",
    "ai",
    "claude"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.com:insurance-future/oh-my-knowledge.git"
  },
  "author": "lizhiyao",
  "license": "MIT",
  "dependencies": {
    "ajv": "^8.18.0",
    "js-yaml": "^4.1.1",
    "simple-statistics": "^7.8.9"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "devDependencies": {
    "eslint": "^10.1.0"
  }
}