{
  "name": "oh-my-knowledge",
  "version": "0.14.0",
  "description": "Knowledge artifact evaluation toolkit — benchmark your skills with objective data",
  "type": "module",
  "bin": {
    "omk": "dist/src/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/src/"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "postbuild": "node -e \"const fs=require('fs'),f='dist/src/cli.js',c=fs.readFileSync(f,'utf8');if(!c.startsWith('#!'))fs.writeFileSync(f,'#!/usr/bin/env node\\n'+c)\"",
    "lint": "eslint 'src/**/*.ts' 'test/**/*.ts'",
    "test": "vitest run",
    "ci": "yarn lint && yarn typecheck && yarn test",
    "prepublishOnly": "yarn build"
  },
  "keywords": [
    "knowledge-engineering",
    "skill-evaluation",
    "benchmark",
    "llm",
    "ai",
    "claude"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.com:insurance-future/oh-my-knowledge.git"
  },
  "author": "lizhiyao",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.89",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "^8.18.0",
    "js-yaml": "^4.1.1",
    "simple-statistics": "^7.8.9"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.3"
  }
}