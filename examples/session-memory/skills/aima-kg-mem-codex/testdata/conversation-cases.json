{
  "version": "1.0.0",
  "description": "Claude Code conversation extraction test cases for aima-kg-mem-codex",
  "cases": [
    {
      "id": "cc-error-resolution-hook-permission",
      "category_under_test": "error_resolution",
      "should_store": true,
      "coverage": [
        "shell hook failure",
        "diagnosis and fix",
        "reusable operational lesson"
      ],
      "conversation": [
        {
          "role": "user",
          "content": "我在 Claude Code 里配置 Stop hook 后报 Permission denied，帮我修。"
        },
        {
          "role": "assistant",
          "content": "我先检查 hook 脚本权限和 shebang。"
        },
        {
          "role": "user",
          "content": "脚本路径没问题，就是执行时报错。"
        },
        {
          "role": "assistant",
          "content": "问题是脚本没有执行权限。解决方式是给脚本加 +x，并确认文件首行有正确的 shebang。"
        },
        {
          "role": "user",
          "content": "修完以后 hook 可以正常跑了。"
        }
      ],
      "expected_extraction": {
        "should_store": true,
        "category": "error_resolution",
        "summary": "Fix hook permission denial",
        "confidence_min": 0.7,
        "keywords": [
          "stop hook",
          "permission denied",
          "chmod",
          "shebang"
        ],
        "request": "Fix a Claude Code Stop hook that failed with Permission denied.",
        "investigated_contains": [
          "hook script permissions",
          "shebang"
        ],
        "learned_contains": [
          "shell hooks need executable permission",
          "shebang should be verified"
        ],
        "completed_contains": [
          "identified missing execute bit",
          "applied executable permission fix"
        ],
        "next_steps_contains": [
          "re-run hook to confirm"
        ],
        "notes_contains": [
          "reusable operational lesson"
        ]
      }
    },
